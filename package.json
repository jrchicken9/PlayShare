{
  "name": "playshare-server",
  "version": "1.0.1",
  "description": "PlayShare platform repo: signaling server, dashboard web shell, browser extension adapter, shared client core (desktop app consumes shared/core over time)",
  "engines": {
    "node": ">=18"
  },
  "main": "server.js",
  "scripts": {
    "version:extension": "node scripts/bump-extension-version.mjs",
    "bump:extension": "node scripts/bump-extension-version.mjs patch",
    "generate:primer": "node scripts/generate-extension-primer.mjs",
    "sync-streaming": "node scripts/sync-streaming.js",
    "build:content": "npm run build:playshare-shared-bundles && esbuild content/src/entry.js --bundle --outfile=content/content.bundle.js --format=iife --platform=browser --target=chrome109 --legal-comments=none --charset=utf8",
    "build:playshare-shared-bundles": "esbuild shared/core/extension-messages-global-entry.js --bundle --format=iife --platform=browser --target=chrome109 --legal-comments=none --charset=utf8 --outfile=shared/core/extension-messages.global.js",
    "build:web": "node scripts/build-dashboard-web.mjs",
    "build:web:lobby": "mkdir -p public/app && esbuild surfaces/dashboard-web/src/main.js --bundle --format=esm --platform=browser --target=es2020 --legal-comments=none --charset=utf8 --outfile=public/app/bundle.js && cp surfaces/dashboard-web/index.html public/app/index.html && cp surfaces/dashboard-web/styles/app.css public/app/app.css",
    "build:content:dev": "npm run build:playshare-shared-bundles && esbuild content/src/entry.js --bundle --outfile=content/content.bundle.js --format=iife --platform=browser --target=chrome109 --legal-comments=none --charset=utf8",
    "build:content:watch": "npm run build:playshare-shared-bundles && esbuild content/src/entry.js --bundle --outfile=content/content.bundle.js --format=iife --platform=browser --target=chrome109 --legal-comments=none --charset=utf8 --watch",
    "package:extension": "bash scripts/package-extension.sh",
    "prepackage:extension": "npm run generate:primer && npm run sync-streaming && npm run build:web && npm run build:content",
    "package:extension:dev": "bash scripts/package-extension-dev.sh",
    "package:extension:both": "bash scripts/package-extension-both.sh",
    "start": "node server.js",
    "dev": "node server.js",
    "worker:diag-ai": "node scripts/run-diag-ai-worker.js",
    "test": "node test/diag-privacy.test.js && node test/diag-intelligence.test.js && node test/diag-intel-auth.test.js && node test/diag-normalize.test.js",
    "test:sync": "node test-sync.js",
    "icons": "node scripts/build-extension-icons.mjs",
    "icons:desktop-mac": "node scripts/build-desktop-mac-icon.mjs",
    "desktop:dev": "npm run dev --prefix apps/desktop",
    "desktop:build:renderer": "npm run build:renderer --prefix apps/desktop",
    "desktop:dist:mac": "npm run dist:mac --prefix apps/desktop",
    "postinstall": "mkdir -p lib && cp node_modules/@supabase/supabase-js/dist/umd/supabase.js lib/supabase.min.js 2>/dev/null || true"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^17.3.1",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "sharp": "^0.33.5"
  }
}
