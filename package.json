{
  "name": "playshare-server",
  "version": "1.0.1",
  "description": "PlayShare WebSocket signaling server for synchronized streaming",
  "engines": {
    "node": ">=18"
  },
  "main": "server.js",
  "scripts": {
    "version:extension": "node scripts/bump-extension-version.mjs",
    "bump:extension": "node scripts/bump-extension-version.mjs patch",
    "generate:primer": "node scripts/generate-extension-primer.mjs",
    "sync-streaming": "node scripts/sync-streaming.js",
    "build:content": "esbuild content/src/entry.js --bundle --outfile=content/content.bundle.js --format=iife --platform=browser --target=chrome109 --legal-comments=none --charset=utf8",
    "build:content:dev": "esbuild content/src/entry.js --bundle --outfile=content/content.bundle.js --format=iife --platform=browser --target=chrome109 --legal-comments=none --charset=utf8",
    "build:content:watch": "esbuild content/src/entry.js --bundle --outfile=content/content.bundle.js --format=iife --platform=browser --target=chrome109 --legal-comments=none --charset=utf8 --watch",
    "package:extension": "bash scripts/package-extension.sh",
    "prepackage:extension": "npm run generate:primer && npm run sync-streaming && npm run build:content",
    "package:extension:dev": "bash scripts/package-extension-dev.sh",
    "package:extension:both": "bash scripts/package-extension-both.sh",
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node test/diag-privacy.test.js && node test/diag-intelligence.test.js && node test/diag-intel-auth.test.js",
    "test:sync": "node test-sync.js",
    "icons": "node scripts/build-extension-icons.mjs",
    "postinstall": "mkdir -p lib && cp node_modules/@supabase/supabase-js/dist/umd/supabase.js lib/supabase.min.js 2>/dev/null || true"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^17.3.1",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "sharp": "^0.33.5"
  }
}
