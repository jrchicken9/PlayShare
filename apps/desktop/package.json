{
  "name": "playshare-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "PlayShare primary desktop client (Windows + macOS): lobby, rooms, invites; reuses shared/core wire protocol. Browser extension remains the streaming-site helper.",
  "author": "PlayShare",
  "main": "electron/main.cjs",
  "scripts": {
    "build:renderer": "esbuild renderer/entry.js --bundle --outfile=renderer/bundle.js --format=iife --platform=browser --target=es2020 --legal-comments=none --charset=utf8",
    "dev": "npm run build:renderer && electron .",
    "start": "npm run dev",
    "predist": "npm run build:renderer",
    "dist": "electron-builder",
    "icons:mac": "node ../../scripts/build-desktop-mac-icon.mjs",
    "dist:mac": "npm run build:renderer && npm run icons:mac && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac"
  },
  "build": {
    "appId": "app.playshare.desktop",
    "productName": "PlayShare",
    "copyright": "Copyright © PlayShare",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "renderer/index.html",
      "renderer/styles.css",
      "renderer/bundle.js",
      "renderer/brand-mark.svg",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "${productName} ${version}"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4"
  }
}
