# Copy to ".env" (gitignored) for local server runs, or set the same names in Railway.
# Never commit real secrets.

# Diagnostic explorer / AI brief (OpenAI-compatible API)
# PLAYSHARE_DIAG_AI_API_KEY=sk-...
# Or use the standard name:
# OPENAI_API_KEY=sk-...

# Optional overrides:
# PLAYSHARE_DIAG_AI_BASE_URL=https://api.openai.com/v1
# PLAYSHARE_DIAG_AI_MODEL=gpt-4o-mini

# Diag intel HTTP API + uploads (extension / explorer Bearer).
# Set one or both. If both are set, they may be different strings — the explorer accepts EITHER value in Authorization.
# PLAYSHARE_DIAG_INTEL_SECRET=...
# PLAYSHARE_DIAG_UPLOAD_SECRET=...
